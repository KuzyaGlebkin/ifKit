{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ifkit",
  "mainBinaryName": "ifkit",
  "version": "../package.json",
  "identifier": "dev.ifkit.game",
  "build": {
    "frontendDist": "../dist-tauri",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run icons:tauri && npm run build:tauri-web"
  },
  "app": {
    "windows": [
      {
        "title": "ifKit Game",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
