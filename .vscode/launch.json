{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Web: Vite (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173/",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "Dev: Vite (npm run dev)"
    },
    {
      "name": "Web: Vite (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173/",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "Dev: Vite (npm run dev)",
      "runtimeExecutable": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
    },
    {
      "name": "Tauri: Dev (Edge для JS)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173/",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "Dev: Tauri (npm run tauri:dev)"
    },
    {
      "name": "Tauri: Dev (Chrome для JS)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173/",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "Dev: Tauri (npm run tauri:dev)",
      "runtimeExecutable": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
    },
    {
      "name": "Web: built HTML (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "file:///${workspaceFolder}/dist/ifkit_0.1.0.html",
